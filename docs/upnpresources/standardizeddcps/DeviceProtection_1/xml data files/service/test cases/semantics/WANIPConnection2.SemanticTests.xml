<ServiceSemanticTestCases>
    <ServiceType>WANIPConnection</ServiceType>
    <ServiceVersion>2</ServiceVersion>
    <TestVersion>0.8</TestVersion>
    <TestGroupList>
        <TestGroup>
            <Id>0</Id>
            <TestCaseList>
               <TestCase>
                    <Id>0</Id>
                    <Action>
                        <UPnPAction>
                            <ActionName>AddPortMapping</ActionName>
                            <InArgs>
                                <NewRemoteHost>1.1.1.1</NewRemoteHost>
                                <NewExternalPort>80</NewExternalPort>
                                <NewProtocol>TCP</NewProtocol>
                                <NewInternalPort>80</NewInternalPort>
                                <NewInternalClient>2.2.2.2</NewInternalClient>
                                <NewEnabled>1</NewEnabled>
                                <NewPortMappingDescription>Test Description</NewPortMappingDescription>
                                <NewLeaseDuration>0</NewLeaseDuration>                                
                            </InArgs>
                            <ExpectedResponse>
                                <SuccessResponse/>
                            </ExpectedResponse>
                        </UPnPAction>
                    </Action>
                    <ExpectedUPnPEventResponse>
                        <MaxWaitTimeToRecvEventsInSecs dataType="ui2">10</MaxWaitTimeToRecvEventsInSecs>
                        <EventedStateVariablesList>
                            <PortMappingNumberOfEntries dataType="ui2">1</PortMappingNumberOfEntries>
                            <SystemUpdateID dataType="ui4">1</SystemUpdateID>
                            <ChangedPortMapping dataType="string">80,80,TCP,2.2.2.2,1.1.1.1</ChangedPortMapping>
                        </EventedStateVariablesList>
                    </ExpectedUPnPEventResponse>
                </TestCase>                
            </TestCaseList>
        </TestGroup>
    </TestGroupList>
</ServiceSemanticTestCases>

<s:Envelope
	xmlns:s="http://schemas.xmlsoap.org/soap/envelope/"
	s:encodingStyle="http://schemas.xmlsoap.org/soap/encoding/">
	<s:Body>
		<m:CreateJob
			xmlns:m="urn:schemas-upnp-org:service:PrintEnhanced:1"
			xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
			xsi:schemaLocation="urn:schemas-upnp-org:service:PrintEnhanced:1 PrintEnhanced.xsd">
			<JobName>Test</JobName>
			<JobOriginatingUserName>Hironori Bouno</JobOriginatingUserName>
			<DocumentFormat>text/html</DocumentFormat>
			<Copies>1</Copies>
			<Sides>device-setting</Sides>
			<NumberUp>device-setting</NumberUp>
			<OrientationRequested>device-setting</OrientationRequested>
			<MediaSize>device-setting</MediaSize>
			<MediaType>device-setting</MediaType>
			<PrintQuality>device-setting</PrintQuality>
		</m:CreateJob>
	</s:Body>
</s:Envelope>

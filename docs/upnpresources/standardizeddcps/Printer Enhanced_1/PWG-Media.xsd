			<simpleType>
				<restriction base="string">
					<enumeration value="photographic-glossy"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="photographic-high-gloss"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="photographic-semi-gloss"/>
				</restriction>

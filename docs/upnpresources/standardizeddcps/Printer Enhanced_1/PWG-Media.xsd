			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="roll"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<pattern value="custom-media-type-[a-z][a-z0-9\-]*"/>
				</restriction>
			</simpleType>
		</union>
	</simpleType>
	<simpleType name="MediaSize">
		<annotation>
			<documentation>Refer to Section 5.</documentation>
		</annotation>
		<union>
			<simpleType>
				<restriction base="string">
					<enumeration value="na_letter_8.5x11in"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="na_legal_8.5x14in"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="iso_a4_210x297mm"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="iso_c5_162x229mm"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="iso_dl_110x220mm"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="jis_b4_257x364mm"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<pattern value="(custom|na|asme|roc|oe)_[a-z0-9][a-z0-9\-]*_([1-9][0-9]*(\.[0-9]*[1-9])?|0\.[0-9]*[1-9])x([1-9][0-9]*(\.[0-9]*[1-9])?|0\.[0-9]*[1-9])in"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<pattern value="(custom|iso|jis|jpn|prc|om)_[a-z0-9][a-z0-9\-]*_([1-9][0-9]*(\.[0-9]*[1-9])?|0\.[0-9]*[1-9])x([1-9][0-9]*(\.[0-9]*[1-9])?|0\.[0-9]*[1-9])mm"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<pattern value="custom_min_[1-9][0-9]*(\.[0-9]*[1-9])?x[1-9][0-9]*(\.[0-9]*[1-9])?(in|mm)"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<pattern value="custom_max_[1-9][0-9]*(\.[0-9]*[1-9])?x[1-9][0-9]*(\.[0-9]*[1-9])?(in|mm)"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="om_small-photo_100x150mm"/>
				</restriction>
			</simpleType>
		</union>
	</simpleType>
</schema>

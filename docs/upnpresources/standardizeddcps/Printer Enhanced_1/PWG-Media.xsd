<schema targetNamespace="urn:schemas-pwg-org:media" xmlns:pwg="urn:schemas-pwg-org:media" xmlns="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified" version="0.91" xml:lang="en">
	<simpleType name="MediaType">
		<annotation>
			<documentation>Refer to Section 3.</documentation>
		</annotation>
		<union>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-coated"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-inkjet"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-preprinted"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-letterhead"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-prepunched"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-fine"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-heavyweight"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="stationery-lightweight"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="transparency"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="envelope"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="envelope-plain"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="envelope-window"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="continuous"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="continuous-long"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="continuous-short"/>
				</restriction>
			</simpleType>
			<simpleType>
				<restriction base="string">
					<enumeration value="tab-stock"/>

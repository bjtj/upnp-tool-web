  <TestGroupList>
    <TestGroup>
      <Id>0</Id>
      <TestCaseList>
        <TestCase>
          <Id>0</Id>
          <Action>
            <ManualAction>
              <ActionInstruction>Turn Device on</ActionInstruction>
              <VerificationInstruction>We 'll start by a ping test</VerificationInstruction>
              <ExpectedSuccessResponse/>
            </ManualAction>
          </Action>
        </TestCase>
        <TestCase>
          <Id>1</Id>
          <Action>
            <UPnPAction>
              <ActionName>Ping</ActionName>
              <InArgs>
                <Host>"127.0.0.1"</Host>
                <NumberOfRepetitions>2</NumberOfRepetitions>
                <Timeout>2</Timeout>
                <DataBlockSize>54</DataBlockSize>
                <DSCP>16</DSCP>
              </InArgs>
              <ExpectedResponse>
                <SuccessResponse>
                  <OutArgsList>
                    <TestID dataType="ui4" SaveAs="PingID"></TestID>
                  </OutArgsList>
                  <RetVal/>
                </SuccessResponse>
              </ExpectedResponse>
            </UPnPAction>
          </Action>
        </TestCase>
        <TestCase>
          <Id>2</Id>
          <Action>
            <ManualAction>
              <ActionInstruction>Waiting Ping response</ActionInstruction>
              <VerificationInstruction>Check that the Ping command is terminated.</VerificationInstruction>
              <ExpectedSuccessResponse/>
            </ManualAction>
          </Action>
        </TestCase>
        <TestCase>
          <Id>3</Id>
          <Action>
            <UPnPAction>
              <ActionName>GetPingResult</ActionName>
              <InArgs>
                <TestID dataType="ui4" LoadAs="PingID"></TestID>
              </InArgs>
              <ExpectedResponse>
                <SuccessResponse>
                  <OutArgsList>
                    <Status dataType="string">Success</Status>
                    <AdditionalInfo dataType="string">None</AdditionalInfo>
                    <SuccessCount dataType="ui4">2</SuccessCount>
                    <FailureCount dataType="ui4">0</FailureCount>
                    <AverageResponseTime dataType="ui4" SaveAs="average"></AverageResponseTime>
                    <MinimumResponseTime dataType="ui4" SaveAs="Minimum"></MinimumResponseTime>
                    <MaximumResponseTime dataType="ui4" SaveAs="Maximum"></MaximumResponseTime>
                  </OutArgsList>
                  <RetVal/>
                </SuccessResponse>
              </ExpectedResponse>
            </UPnPAction>
          </Action>
        </TestCase>
      </TestCaseList>
    </TestGroup>

<ServiceControlSyntaxTestCases>
	<ServiceType>QosManager</ServiceType>
	<ServiceVersion>1</ServiceVersion>
  <TestVersion>0.9</TestVersion>
	<TestCaseList>
		<TestCase>
			<Id>1</Id>
			<Category>Valid Action And Valid InArgs</Category>
			<ActionName>RequestTrafficQos</ActionName>
			<InArgs>
			<InitialTrafficDescriptor>&lt;TrafficDescriptor&gt;
			&lt;TrafficId&gt;
			&lt;SourceAddress&gt;
			&lt;Ipv4&gt;192.168.1.104&lt;/Ipv4&gt;
			&lt;PrefixLength&gt;24&lt;/PrefixLength&gt;
			&lt;/SourceAddress&gt;
			&lt;SourcePort&gt;23&lt;/SourcePort&gt;
			&lt;DestinationAddress&gt;
	            &lt;Ipv4&gt;192.168.1.53&lt;/Ipv4&gt;
			&lt;PrefixLength&gt;24&lt;/PrefixLength&gt;
			&lt;/DestinationAddress&gt;
          		&lt;DestinationPort&gt;23&lt;/DestinationPort&gt;
          		&lt;IpProtocol&gt;1&lt;/IpProtocol&gt;
			&lt;/TrafficId&gt;
			&lt;AvailableOrderedTspecList&gt;
			&lt;Tspec&gt;
			&lt;TspecIndex&gt;2&lt;/TspecIndex&gt;
			&lt;MeanDataRate&gt;10000&lt;/MeanDataRate&gt;
			&lt;PeakDataRate&gt;20000&lt;/PeakDataRate&gt;
			&lt;TrafficClass&gt;Gaming&lt;/TrafficClass&gt;
			&lt;/Tspec&gt;
			&lt;/AvailableOrderedTspecList&gt;
			&lt;TrafficLeaseTime&gt;6666&lt;/TrafficLeaseTime&gt;
   		   	&lt;v2&gt;
                	&lt;PolicyHolderId&gt;uuid:Intel-Com-QosPolicyHolder-T001:serviceId:qphT2&lt;/PolicyHolderId&gt;
		      &lt;/v2&gt;
			&lt;/TrafficDescriptor&gt;</InitialTrafficDescriptor>
			</InArgs>
			<ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>
		</TestCase>
			<TestCase>
			<Id>2</Id>
			<Category>Valid Action And Valid InArgs</Category>
			<ActionName>BrowseAllTrafficDescriptors</ActionName>
			<ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>
		</TestCase>
		<TestCase>
			<Id>3</Id>
			<Category>Valid Action And Valid InArgs</Category>
			<ActionName>UpdateTrafficQos</ActionName>
			<InArgs>
				<TrafficHandle>any-string</TrafficHandle>
				<RequestedTrafficDescriptor>&lt;TrafficDescriptor&gt;
			&lt;TrafficId&gt;
			&lt;SourceAddress&gt;
			&lt;Ipv4&gt;192.168.1.104&lt;/Ipv4&gt;
			&lt;PrefixLength&gt;24&lt;/PrefixLength&gt;
			&lt;/SourceAddress&gt;
			&lt;SourcePort&gt;23&lt;/SourcePort&gt;
			&lt;DestinationAddress&gt;
	            &lt;Ipv4&gt;192.168.1.53&lt;/Ipv4&gt;
			&lt;PrefixLength&gt;24&lt;/PrefixLength&gt;
			&lt;/DestinationAddress&gt;
          		&lt;DestinationPort&gt;23&lt;/DestinationPort&gt;
          		&lt;IpProtocol&gt;1&lt;/IpProtocol&gt;
			&lt;/TrafficId&gt;
			&lt;AvailableOrderedTspecList&gt;
			&lt;Tspec&gt;
			&lt;TspecIndex&gt;2&lt;/TspecIndex&gt;
			&lt;MeanDataRate&gt;10000&lt;/MeanDataRate&gt;
			&lt;PeakDataRate&gt;20000&lt;/PeakDataRate&gt;
			&lt;TrafficClass&gt;Gaming&lt;/TrafficClass&gt;
			&lt;/Tspec&gt;
			&lt;/AvailableOrderedTspecList&gt;
			&lt;TrafficLeaseTime&gt;6666&lt;/TrafficLeaseTime&gt;
   		   	&lt;v2&gt;
                	&lt;PolicyHolderId&gt;uuid:Intel-Com-QosPolicyHolder-T001:serviceId:qphT2&lt;/PolicyHolderId&gt;
		      &lt;/v2&gt;
			&lt;/TrafficDescriptor&gt;</RequestedTrafficDescriptor>
			</InArgs>
			<ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>
		</TestCase>
		<TestCase>
			<Id>4</Id>
			<Category>Valid Action And Valid InArgs</Category>
			<ActionName>ReleaseTrafficQos</ActionName>
			<InArgs>
				<RevokeTrafficHandle>any-string</RevokeTrafficHandle>
			</InArgs>
			<ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>
		</TestCase>
	</TestCaseList>
</ServiceControlSyntaxTestCases>
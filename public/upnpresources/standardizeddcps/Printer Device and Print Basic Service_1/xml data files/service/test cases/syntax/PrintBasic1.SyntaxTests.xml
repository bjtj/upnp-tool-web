<ServiceControlSyntaxTestCases>

<ServiceType>PrintBasic</ServiceType> 

<ServiceVersion>1</ServiceVersion> 

<TestCaseList> 

  <TestCase> 

    <Id>0</Id> 

    <Category>Valid Action And Valid InArgs</Category> 

    <ActionName>CreateJob</ActionName> 

    <InArgs> 

      
      <JobName>JohnDoe's Job</JobName> 

      <JobOriginatingUserName>JohnDoe</JobOriginatingUserName>

      <DocumentFormat>application/vnd.pwg-xhtml-print</DocumentFormat>

      <Copies>1</Copies>

      <Sides>one-sided</Sides>

      <NumberUp>1</NumberUp>

      <OrientationRequested>portrait</OrientationRequested>

      <MediaSize>device-setting</MediaSize>

      <MediaType>device-setting</MediaType>
 
      <PrintQuality>normal</PrintQuality>

   </InArgs>


    <ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode> 

  </TestCase>

  <TestCase>

    <Id>1</Id>

    <Category>Valid Action And Valid InArgs</Category>

    <ActionName>GetPrinterAttributes</ActionName>

    <ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>

  </TestCase>

  <TestCase>

    <Id>2</Id>

    <Category>Valid Action And Valid InArgs</Category>

    <ActionName>GetJobAttributes</ActionName>
     <InArgs>

      <JobId>10</JobId>

     </InArgs> 
  
     <ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>

      
  </TestCase>
  <TestCase>

    <Id>3</Id>

    <Category>Valid Action And Valid InArgs</Category>

    <ActionName>CancelJob</ActionName>

    <InArgs>

      <JobId>10</JobId>

    </InArgs> 

    <ExpectedReturnCode>ACTION_AND_INARGS_ARE_VALID</ExpectedReturnCode>

  </TestCase>
 

</TestCaseList>

</ServiceControlSyntaxTestCases>
